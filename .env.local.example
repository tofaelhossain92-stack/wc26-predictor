# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Football Data API ─────────────────────────────────────────────────────────
# Free tier at: https://www.football-data.org/client/register
FOOTBALL_API_KEY=your-football-api-key-here

# ── OneSignal Push Notifications ─────────────────────────────────────────────
# Get these from: https://onesignal.com → Your App → Settings → Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id-here
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key-here

# ── Vercel Cron Secret ────────────────────────────────────────────────────────
# Make up any random string — used to secure the cron endpoint
CRON_SECRET=make-up-any-random-string-here
